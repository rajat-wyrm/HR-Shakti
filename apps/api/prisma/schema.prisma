generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgcrypto, ltree]
}

// ============================================================
// ENUMS
// ============================================================

enum Role {
  super_admin
  admin
  moderator
  member
  guest
}

enum UserStatus {
  active
  suspended
  banned
  pending_verification
}

enum ConnectionStatus {
  pending
  accepted
  blocked
}

enum CommunityAccessType {
  public
  restricted
  private
}

enum DiscussionSortType {
  trending
  best
  latest
  most_discussed
  controversial
}

enum BlogPostStatus {
  draft
  peer_review
  editorial_review
  published
  archived
  featured
  trending
}

enum EventType {
  online
  in_person
  hybrid
}

enum EventStatus {
  draft
  published
  cancelled
  completed
}

enum NotificationChannel {
  in_app
  email
  both
}

enum ReactionType {
  helpful
  insightful
  from_experience
  inaccurate
}

enum ReportStatus {
  pending
  reviewed
  dismissed
  action_taken
}

enum ModerationActionType {
  content_removed
  user_warned
  user_suspended
  user_banned
  feature_restricted
}

// ============================================================
// 1. USERS & AUTH
// ============================================================

model User {
  id                     String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                  String     @unique @db.VarChar(255)
  passwordHash           String?    @map("password_hash") @db.VarChar(255)
  firstName              String     @map("first_name") @db.VarChar(100)
  lastName               String     @map("last_name") @db.VarChar(100)
  username               String     @unique @db.VarChar(50)
  avatarUrl              String?    @map("avatar_url") @db.VarChar(500)
  headline               String?    @db.VarChar(200)
  about                  String?    @db.Text
  locationCity           String?    @map("location_city") @db.VarChar(100)
  locationCountry        String?    @map("location_country") @db.VarChar(100)
  locationState          String?    @map("location_state") @db.VarChar(100)
  timezone               String     @default("UTC") @db.VarChar(50)
  website                String?    @db.VarChar(500)
  linkedinUrl            String?    @map("linkedin_url") @db.VarChar(500)
  twitterUrl             String?    @map("twitter_url") @db.VarChar(500)
  profileCompletionPct   Int        @default(0) @map("profile_completion_pct") @db.SmallInt
  isVerified             Boolean    @default(false) @map("is_verified")
  isProfessionalVerified Boolean   @default(false) @map("is_professional_verified")
  role                   Role       @default(member)
  trustLevel             Int        @default(1) @map("trust_level") @db.SmallInt
  reputationScore        Int        @default(0) @map("reputation_score")
  status                 UserStatus @default(active)
  suspensionReason       String?    @map("suspension_reason")
  suspendedAt            DateTime?  @map("suspended_at") @db.Timestamptz
  suspendedBy            String?    @map("suspended_by") @db.Uuid
  lastLoginAt            DateTime?  @map("last_login_at") @db.Timestamptz
  lastActivityAt         DateTime?  @map("last_activity_at") @db.Timestamptz
  onboardingCompleted    Boolean    @default(false) @map("onboarding_completed")
  onboardingStep         Int        @default(1) @map("onboarding_step") @db.SmallInt
  preferences            Json       @default("{}")
  createdAt              DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt              DateTime?  @map("deleted_at") @db.Timestamptz

  suspendedByUser      User?                    @relation("UserSuspension", fields: [suspendedBy], references: [id])
  suspendedUsers       User[]                   @relation("UserSuspension")
  credentials          UserCredential[]
  sessions             Session[]
  emailTokens          EmailVerificationToken[]
  passwordResets       PasswordResetToken[]
  loginAttempts        FailedLoginAttempt[]
  experiences          UserExperience[]
  education            UserEducation[]
  certifications      UserCertification[]
  skills              UserSkill[]
  connectionsSent      Connection[]             @relation("ConnectionRequester")
  connectionsReceived  Connection[]             @relation("ConnectionTarget")
  followers            Follow[]                 @relation("FollowTarget")
  following            Follow[]                 @relation("FollowFollower")
  blocksInitiated      Block[]                  @relation("BlockInitiator")
  blocksTargeted       Block[]                  @relation("BlockTarget")
  orgMemberships       OrganizationMember[]
  orgClaims            OrganizationClaim[]
  communityMemberships CommunityMember[]
  communityModerations CommunityModerator[]
  discussions          Discussion[]
  discussionComments   DiscussionComment[]
  pollVotes            DiscussionPollVote[]
  bookmarks            DiscussionBookmark[]
  questions            Question[]
  answers              Answer[]
  blogPosts            BlogPost[]
  blogComments         BlogComment[]
  enrollments          Enrollment[]
  lessonProgress       LessonProgress[]
  assessmentAttempts   AssessmentAttempt[]
  studyGroupMembers    StudyGroupMember[]
  reactions            ContentReaction[]
  bookmarksPolymorphic ContentBookmark[]
  reports              ContentReport[]
  notifications        Notification[]
  notificationPrefs    NotificationPreference[]
  conversationParts    ConversationParticipant[]
  messages             Message[]
  aiConversations      AiConversation[]
  aiMessages           AiMessage[]
  aiUsage              AiUsageLog[]
  employerReviews      EmployerReview[]
  vendorReviews        VendorReview[]
  salaryBenchmarks     SalaryBenchmark[]
  mentorshipProfiles   MentorshipProfile[]
  mentorshipRequestsSent     MentorshipRequest[]    @relation("MentorshipRequester")
  mentorshipRequestsReceived MentorshipRequest[]    @relation("MentorshipMentor")
  mentorshipGoals      MentorshipGoal[]
  mentorshipSessions   MentorshipSession[]
  mentorshipFeedback   MentorshipFeedback[]
  selfAssessments      SelfAssessment[]
  badges               UserBadge[]
  reputationEvents     ReputationEvent[]
  auditLogs            AuditLog[]
  moderationActions    ModerationAction[]
  newsReads            NewsRead[]
  userComplianceAlerts UserComplianceAlert[]
  eventRegistrations   EventRegistration[]

  @@index([status])
  @@index([role])
  @@index([isProfessionalVerified])
  @@index([trustLevel])
  @@index([locationCountry])
  @@index([lastActivityAt])
  @@index([createdAt])
  @@map("users")
}

model UserCredential {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  provider          String   @db.VarChar(50)
  providerAccountId String   @map("provider_account_id") @db.VarChar(255)
  accessToken       String?  @map("access_token") @db.Text
  refreshToken      String?  @map("refresh_token") @db.Text
  tokenExpiresAt    DateTime? @map("token_expires_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("user_credentials")
}

model Session {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  refreshTokenHash String   @map("refresh_token_hash") @db.VarChar(255)
  userAgent        String?  @map("user_agent") @db.VarChar(500)
  ipAddress        String?  @map("ip_address") @db.VarChar(45)
  deviceInfo       String?  @map("device_info") @db.Text
  expiresAt        DateTime @map("expires_at") @db.Timestamptz
  isRevoked        Boolean  @default(false) @map("is_revoked")
  lastActiveAt     DateTime? @map("last_active_at") @db.Timestamptz
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshTokenHash])
  @@map("sessions")
}

model EmailVerificationToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  token     String    @unique @db.Uuid
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model FailedLoginAttempt {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  ipAddress   String   @map("ip_address") @db.VarChar(45)
  attemptedAt DateTime @default(now()) @map("attempted_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([attemptedAt])
  @@map("failed_login_attempts")
}

// ============================================================
// 2. PROFILE
// ============================================================

model UserExperience {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  title       String   @db.VarChar(200)
  company     String   @db.VarChar(200)
  companyId   String?  @map("company_id") @db.Uuid
  location    String?  @db.VarChar(100)
  isCurrent   Boolean  @default(false) @map("is_current")
  startDate   DateTime @map("start_date") @db.Date
  endDate     DateTime? @map("end_date") @db.Date
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_experiences")
}

model UserEducation {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  institution   String   @db.VarChar(200)
  degree        String?  @db.VarChar(200)
  fieldOfStudy  String?  @map("field_of_study") @db.VarChar(200)
  startDate     DateTime @map("start_date") @db.Date
  endDate       DateTime? @map("end_date") @db.Date
  grade         String?  @db.VarChar(50)
  description   String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_education")
}

model UserCertification {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String   @db.VarChar(200)
  issuingOrg      String   @map("issuing_org") @db.VarChar(200)
  credentialId    String?  @map("credential_id") @db.VarChar(200)
  credentialUrl   String?  @map("credential_url") @db.VarChar(500)
  earnedDate      DateTime @map("earned_date") @db.Date
  expirationDate  DateTime? @map("expiration_date") @db.Date
  isVerified      Boolean  @default(false) @map("is_verified")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_certifications")
}

model UserSkill {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  skill     String   @db.VarChar(100)
  endorsements Int  @default(0)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skill])
  @@index([userId])
  @@map("user_skills")
}

// ============================================================
// 3. NETWORK
// ============================================================

model Connection {
  id         String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterId String          @map("requester_id") @db.Uuid
  targetId   String           @map("target_id") @db.Uuid
  status     ConnectionStatus @default(pending)
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  requester User @relation("ConnectionRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  target    User @relation("ConnectionTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([requesterId, targetId])
  @@index([requesterId])
  @@index([targetId])
  @@index([status])
  @@map("connections")
}

model Follow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid
  targetId    String   @map("target_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  follower User @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  target   User @relation("FollowTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([followerId, targetId])
  @@index([followerId])
  @@index([targetId])
  @@map("follows")
}

model Block {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  initiatorId String   @map("initiator_id") @db.Uuid
  targetId    String   @map("target_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  initiator User @relation("BlockInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  target    User @relation("BlockTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([initiatorId, targetId])
  @@map("blocks")
}

// ============================================================
// 4. ORGANIZATIONS
// ============================================================

model Organization {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String   @db.VarChar(200)
  slug              String   @unique @db.VarChar(200)
  description       String?  @db.Text
  logoUrl           String?  @map("logo_url") @db.VarChar(500)
  website           String?  @db.VarChar(500)
  industry          String?  @db.VarChar(100)
  companySize       String?  @map("company_size") @db.VarChar(50)
  headquarters      String?  @db.VarChar(200)
  foundedYear       Int?     @map("founded_year")
  isVerified        Boolean  @default(false) @map("is_verified")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  members      OrganizationMember[]
  claims       OrganizationClaim[]
  employerReviews EmployerReview[]

  @@index([slug])
  @@index([industry])
  @@map("organizations")
}

model OrganizationMember {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           String   @default("member") @db.VarChar(50)
  title          String?  @db.VarChar(200)
  isPublic       Boolean  @default(true) @map("is_public")
  joinedAt       DateTime @default(now()) @map("joined_at") @db.Timestamptz
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model OrganizationClaim {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  organizationId    String   @map("organization_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  workEmail         String   @map("work_email") @db.VarChar(255)
  verificationToken String?  @map("verification_token") @db.VarChar(255)
  status            String   @default("pending") @db.VarChar(50)
  reviewedBy        String?  @map("reviewed_by") @db.Uuid
  reviewedAt        DateTime? @map("reviewed_at") @db.Timestamptz
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@map("organization_claims")
}

// ============================================================
// 5. COMMUNITIES
// ============================================================

model Community {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String   @db.VarChar(200)
  slug              String   @unique @db.VarChar(200)
  description       String?  @db.Text
  iconUrl           String?  @map("icon_url") @db.VarChar(500)
  bannerUrl         String?  @map("banner_url") @db.VarChar(500)
  accessType        CommunityAccessType @default(public) @map("access_type")
  memberCount       Int      @default(0) @map("member_count")
  discussionCount   Int      @default(0) @map("discussion_count")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt         DateTime? @map("deleted_at") @db.Timestamptz

  members     CommunityMember[]
  moderators  CommunityModerator[]
  discussions Discussion[]

  @@index([slug])
  @@index([accessType])
  @@map("communities")
}

model CommunityMember {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId String   @map("community_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  joinedAt    DateTime @default(now()) @map("joined_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@map("community_members")
}

model CommunityModerator {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId String   @map("community_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  addedAt     DateTime @default(now()) @map("added_at") @db.Timestamptz
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([communityId, userId])
  @@index([communityId])
  @@index([userId])
  @@map("community_moderators")
}

// ============================================================
// 6. DISCUSSIONS
// ============================================================

model Discussion {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  communityId     String   @map("community_id") @db.Uuid
  authorId        String   @map("author_id") @db.Uuid
  title           String   @db.VarChar(300)
  content         String   @db.Text
  contentType     String   @default("text") @map("content_type") @db.VarChar(20)
  tags            Json     @default("[]")
  isAnonymous     Boolean  @default(false) @map("is_anonymous")
  anonymousAuthorId String? @map("anonymous_author_id") @db.Uuid
  helpfulCount    Int      @default(0) @map("helpful_count")
  insightfulCount Int      @default(0) @map("insightful_count")
  fromExpCount    Int      @default(0) @map("from_exp_count")
  inaccurateCount Int      @default(0) @map("inaccurate_count")
  commentCount    Int      @default(0) @map("comment_count")
  bookmarkCount   Int      @default(0) @map("bookmark_count")
  viewCount       Int      @default(0) @map("view_count")
  qualityScore    Float    @default(0) @map("quality_score")
  isPinned        Boolean  @default(false) @map("is_pinned")
  isLocked        Boolean  @default(false) @map("is_locked")
  status          String   @default("active") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  DiscussionComment[]
  polls     DiscussionPoll[]
  bookmarks DiscussionBookmark[]

  @@index([communityId])
  @@index([authorId])
  @@index([createdAt])
  @@index([qualityScore])
  @@index([status])
  @@map("discussions")
}

model DiscussionComment {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  discussionId    String   @map("discussion_id") @db.Uuid
  parentId        String?  @map("parent_id") @db.Uuid
  authorId        String   @map("author_id") @db.Uuid
  content         String   @db.Text
  path            String?  @db.VarChar(255)
  depth           Int      @default(0)
  helpfulCount    Int      @default(0) @map("helpful_count")
  insightfulCount Int      @default(0) @map("insightful_count")
  fromExpCount    Int      @default(0) @map("from_exp_count")
  isAnonymous     Boolean  @default(false) @map("is_anonymous")
  isAcceptedAnswer Boolean @default(false) @map("is_accepted_answer")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent     DiscussionComment? @relation("CommentHierarchy", fields: [parentId], references: [id])
  replies    DiscussionComment[] @relation("CommentHierarchy")

  @@index([discussionId])
  @@index([authorId])
  @@index([path])
  @@map("discussion_comments")
}

model DiscussionPoll {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  discussionId String   @map("discussion_id") @db.Uuid
  question     String   @db.VarChar(500)
  isMultiple   Boolean  @default(false) @map("is_multiple")
  expiresAt    DateTime? @map("expires_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  discussion Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  options    DiscussionPollOption[]

  @@index([discussionId])
  @@map("discussion_polls")
}

model DiscussionPollOption {
  id      String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pollId  String @map("poll_id") @db.Uuid
  label   String @db.VarChar(200)
  voteCount Int  @default(0) @map("vote_count")

  poll   DiscussionPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  DiscussionPollVote[]

  @@index([pollId])
  @@map("discussion_poll_options")
}

model DiscussionPollVote {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  optionId String @map("option_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid
